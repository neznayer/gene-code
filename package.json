{
  "name": "gene-code",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "packages/*"
  ],
  "private": true,
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun scripts/pin-workspace-deps.ts && changeset publish",
    "build:core": "bun --filter=@gene-code/core run build ",
    "build:rehype": "bun --filter=@gene-code/rehype run build"
  }
}
